   <!-- Detailed Gamelist size changes depending on metadata -->
   <!-- Detailed Gamelist metadata:on-->
   <variables ifSubset="metadata:on">
        <!-- Game List -->
        <gamelistPos>0.5 0.45</gamelistPos>
        <gamelistSize>0.28 0.67</gamelistSize>
        <!-- Game List Background -->
        <gamelistBackgroundPos>0.5 0.45648148147</gamelistBackgroundPos>
        <gamelistBackgroundSize>0.3 0.72</gamelistBackgroundSize>
        <!-- Game List Background Shadow -->
        <gamelistShadowPos>0.5 0.45648148147</gamelistShadowPos>
        <gamelistShadowSize>0.3 0.7972222528</gamelistShadowSize>
   </variables>
   <!-- Detailed Gamelist metadata:off-->
   <variables ifSubset="metadata:off">
        <!-- Game List -->
        <gamelistPos>0.5 0.5</gamelistPos>
        <gamelistSize>0.28 0.72</gamelistSize>
        <!-- Game List Background -->
        <gamelistBackgroundPos>0.5 0.50648148147</gamelistBackgroundPos>
        <gamelistBackgroundSize>0.3 0.82</gamelistBackgroundSize>
        <!-- Game List Background Shadow -->
        <gamelistShadowPos>0.5 0.50648148147</gamelistShadowPos>
        <gamelistShadowSize>0.3 0.8972222528</gamelistShadowSize>
   </variables>

	<variables>
		<CornersGrid>5</CornersGrid>
		<CornersSmall>10</CornersSmall>
		<CornersMedium>20</CornersMedium>
		<CornersLarge>30</CornersLarge>
	</variables>



</theme>
