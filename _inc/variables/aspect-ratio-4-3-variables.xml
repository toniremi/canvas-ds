<theme>
	<formatVersion>7</formatVersion>

<!--
4:3 aspect ratio variables
based on 640x480
-->

	<!-- Variables -->
	<!-- ~~~~~~~~~~~ -->
	<variables ifSubset="font-size:small">
            <systemDescriptionFontSize>0.015</systemDescriptionFontSize>
            <systemYearFontSize>0.020</systemYearFontSize>
            <systemInfoFontSize>0.04</systemInfoFontSize>
            <indicatorFontSize>0.035</indicatorFontSize>
			<itemcount>3.5</itemcount>
