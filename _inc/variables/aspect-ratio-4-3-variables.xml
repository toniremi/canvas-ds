            <helpFontSizeSmall>0.015</helpFontSizeSmall>
            <helpPos>0.97</helpPos>
            <helpPosSmall>0.03</helpPosSmall>
            <gamelistBackgroundImageCalculated
        >./_inc/images/gamelist/${gamelistBackgroundImage}-small.webp</gamelistBackgroundImageCalculated>
            <gamelistFontSize>0.022</gamelistFontSize>
            <gamelistSelectorHeight>0.039814814814815</gamelistSelectorHeight>
            <itemSizeCarousel>0.20 0.25</itemSizeCarousel>
